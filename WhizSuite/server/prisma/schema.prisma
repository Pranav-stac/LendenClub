generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USER & AUTH ============

model User {
  id            String    @id
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  avatarUrl     String?
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  // Relations
  refreshTokens    RefreshToken[]
  workspaces       Workspace[]       @relation("WorkspaceOwner")
  memberships      WorkspaceMember[]
  posts            Post[]            @relation("PostCreator")
  calendarEvents   CalendarEvent[]
  reviewLinks      ReviewLink[]
  notifications    Notification[]    @relation("NotificationCreator")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ WORKSPACE & TEAMS ============

model Workspace {
  id               String   @id
  name             String
  slug             String   @unique
  description      String?
  logoUrl          String?
  ownerId          String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  plan             String   @default("free")
  billingEmail     String?
  stripeCustomerId String?

  // Relations
  owner       User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members     WorkspaceMember[]
  roles       Role[]
  clients     Client[]
  brands      Brand[]
  posts       Post[]
  events        CalendarEvent[]
  reviewLinks   ReviewLink[]
  invitations   Invitation[]
  mediaFiles    MediaFile[]
  notifications Notification[]
}

model WorkspaceMember {
  id          String   @id
  workspaceId String
  userId      String
  roleId      String
  isActive    Boolean  @default(true)
  joinedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace    Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role                @relation(fields: [roleId], references: [id])
  clientAccess ClientMemberAccess[]
  brandAccess  BrandMemberAccess[]

  @@unique([workspaceId, userId])
}

model Role {
  id          String   @id
  workspaceId String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members     WorkspaceMember[]
  permissions RolePermission[]
  invitations Invitation[]

  @@unique([workspaceId, name])
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  category    String
  createdAt   DateTime @default(now())

  roles RolePermission[]
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Invitation {
  id          String    @id
  workspaceId String
  email       String
  roleId      String
  token       String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id])

  @@unique([workspaceId, email])
}

// ============ CLIENTS & BRANDS ============

model Client {
  id            String   @id
  workspaceId   String
  name          String
  email         String?
  phone         String?
  website       String?
  logoUrl       String?
  description   String?
  industry      String?
  contactPerson String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brands    Brand[]
  events    CalendarEvent[]
  memberAccess ClientMemberAccess[]
}

model Brand {
  id             String   @id
  workspaceId    String
  clientId       String
  name           String
  description    String?
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  website        String?
  guidelines     String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client              Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platformConnections PlatformConnection[]
  posts               Post[]
  events              CalendarEvent[]
  memberAccess        BrandMemberAccess[]
}

// ============ PLATFORMS ============

model Platform {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  icon        String?
  color       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  connections PlatformConnection[]
  postPlatforms PostPlatform[]
}

model PlatformConnection {
  id               String    @id
  brandId          String
  platformId       String
  accessToken      String
  refreshToken     String?
  tokenExpiry      DateTime?
  platformUserId   String?
  platformUsername String?
  profileUrl       String?
  metadata         Json?
  isActive         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  platform Platform @relation(fields: [platformId], references: [id])

  @@unique([brandId, platformId])
}

// ============ POSTS & SCHEDULING ============

model Post {
  id                 String    @id
  workspaceId        String
  brandId            String
  createdById        String
  content            String
  postType           String    @default("post") // post, carousel, reel, trial_reel, story
  mediaUrls          String[]  @default([])
  hashtags           String[]  @default([])
  mentions           String[]  @default([])
  coverUrl           String?   // Cover image for reels
  altText            String?   // Alt text for images (accessibility)
  shareToFeed        Boolean   @default(true) // For reels - also share to feed
  trialGraduationStrategy String? // MANUAL or SS_PERFORMANCE for trial reels
  audioName          String?   // Original audio name for reels
  userTags           Json?     // [{username, x, y}] up to 20
  locationId         String?   // Facebook Page ID for tagged location
  collaborators      String[]  @default([]) // Usernames for co-authoring (up to 3)
  thumbOffset        Int?      // Video frame offset in ms for thumbnail
  platformVariations Json?
  status             String    @default("DRAFT") // DRAFT, SCHEDULED, PUBLISHING, PUBLISHED, FAILED
  scheduledAt        DateTime?
  publishedAt        DateTime?
  approvedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand       Brand           @relation(fields: [brandId], references: [id], onDelete: Cascade)
  createdBy   User            @relation("PostCreator", fields: [createdById], references: [id])
  platforms   PostPlatform[]
  events      CalendarEvent[]
  reviewPosts ReviewPost[]
}

model PostPlatform {
  id          String    @id @default(cuid())
  postId      String
  platformId  String
  platformPostId String?
  status      String    @default("PENDING") // PENDING, PUBLISHED, FAILED
  publishedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  platform Platform @relation(fields: [platformId], references: [id])
}

// ============ CALENDAR ============

model CalendarEvent {
  id          String    @id
  workspaceId String
  createdById String
  title       String
  description String?
  type        String    @default("OTHER") // POST, MEETING, DEADLINE, REMINDER, OTHER
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean   @default(false)
  brandId     String?
  clientId    String?
  postId      String?
  color       String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id])
  brand     Brand?    @relation(fields: [brandId], references: [id])
  client    Client?   @relation(fields: [clientId], references: [id])
  post      Post?     @relation(fields: [postId], references: [id])
}

// ============ REVIEWS ============

model ReviewLink {
  id            String    @id
  workspaceId   String
  createdById   String
  name          String
  token         String    @unique
  expiresAt     DateTime?
  allowComments Boolean   @default(true)
  allowApproval Boolean   @default(true)
  password      String?
  isActive      Boolean   @default(true)
  viewCount     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User         @relation(fields: [createdById], references: [id])
  posts     ReviewPost[]
}

model ReviewPost {
  id           String   @id
  reviewLinkId String
  postId       String
  createdAt    DateTime @default(now())

  reviewLink ReviewLink       @relation(fields: [reviewLinkId], references: [id], onDelete: Cascade)
  post       Post             @relation(fields: [postId], references: [id], onDelete: Cascade)
  feedback   ReviewFeedback[]

  @@unique([reviewLinkId, postId])
}

model ReviewFeedback {
  id            String   @id @default(cuid())
  reviewPostId  String
  status        String   // APPROVED, REJECTED, NEEDS_CHANGES
  comment       String?
  reviewerName  String?
  reviewerEmail String?
  createdAt     DateTime @default(now())

  reviewPost ReviewPost @relation(fields: [reviewPostId], references: [id], onDelete: Cascade)
}

// ============ CLIENT/BRAND MEMBER ACCESS ============

model ClientMemberAccess {
  id         String   @id @default(cuid())
  clientId   String
  memberId   String
  createdAt  DateTime @default(now())

  client Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  member WorkspaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([clientId, memberId])
}

model BrandMemberAccess {
  id         String   @id @default(cuid())
  brandId    String
  memberId   String
  createdAt  DateTime @default(now())

  brand  Brand           @relation(fields: [brandId], references: [id], onDelete: Cascade)
  member WorkspaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([brandId, memberId])
}

// ============ MEDIA ============

model MediaFile {
  id           String   @id
  workspaceId  String
  filename     String
  originalName String
  url          String
  mimeType     String
  size         Int
  type         String   // IMAGE, VIDEO, DOCUMENT
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ============ NOTIFICATIONS & REMINDERS ============

model Notification {
  id            String    @id
  workspaceId   String
  createdById   String
  
  // Content
  title         String
  body          String
  richBody      String?   // HTML/Markdown rich content (for emails)
  templateId    String?   // Optional: use a template
  templateData  Json?     // Data to fill template placeholders
  
  // Targeting
  channel       String    // EMAIL, WHATSAPP, IN_APP, SMS, PUSH, WEBHOOK
  recipients    Json      // Array of { type: 'user'|'email'|'phone'|'webhook', value: string, name?: string }
  
  // Categorization
  category      String    @default("GENERAL") // GENERAL, REMINDER, TEAM, POST, DEADLINE, ALERT, CUSTOM
  priority      String    @default("NORMAL")  // LOW, NORMAL, HIGH, URGENT
  
  // Scheduling
  status        String    @default("DRAFT")   // DRAFT, SCHEDULED, SENDING, SENT, PARTIALLY_SENT, FAILED, CANCELLED
  scheduledAt   DateTime?
  sentAt        DateTime?
  
  // Recurrence (for recurring reminders)
  isRecurring   Boolean   @default(false)
  recurrenceRule String?  // RRULE format: FREQ=DAILY;INTERVAL=1;COUNT=10
  recurrenceEnd DateTime?
  lastTriggeredAt DateTime?
  nextTriggerAt   DateTime?
  
  // References (link to any entity)
  referenceType String?   // POST, EVENT, CLIENT, BRAND, REVIEW, CUSTOM
  referenceId   String?
  
  // Metadata
  metadata      Json?     // Any extra data (link URLs, action buttons, etc.)
  tags          String[]  @default([])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy     User                 @relation("NotificationCreator", fields: [createdById], references: [id])
  template      NotificationTemplate? @relation(fields: [templateId], references: [id])
  logs          NotificationLog[]
}

model NotificationTemplate {
  id            String   @id
  workspaceId   String?  // null = system-wide template
  
  name          String
  slug          String   @unique
  description   String?
  
  channel       String   // EMAIL, WHATSAPP, IN_APP, SMS, PUSH, WEBHOOK
  category      String   @default("GENERAL")
  
  // Template content with {{placeholder}} support
  subject       String?  // For emails
  body          String   // Plain text body with {{placeholders}}
  richBody      String?  // HTML body with {{placeholders}}
  
  // WhatsApp-specific
  whatsappTemplateName String?
  whatsappLanguage     String?  @default("en")
  
  isActive      Boolean  @default(true)
  isSystem      Boolean  @default(false) // System templates can't be deleted
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  notifications Notification[]
}

model NotificationLog {
  id              String    @id @default(cuid())
  notificationId  String
  
  // Recipient info
  recipientType   String    // user, email, phone, webhook
  recipientValue  String    // user ID, email address, phone number, webhook URL
  recipientName   String?
  
  // Delivery status
  channel         String    // EMAIL, WHATSAPP, IN_APP, SMS, PUSH, WEBHOOK
  status          String    @default("PENDING") // PENDING, SENT, DELIVERED, READ, FAILED, BOUNCED
  
  // Provider info
  providerName    String?   // nodemailer, twilio, whatsapp-api, firebase, etc.
  providerMessageId String? // External message ID from provider
  
  // Error tracking
  error           String?
  retryCount      Int       @default(0)
  maxRetries      Int       @default(3)
  lastRetryAt     DateTime?
  
  // Timestamps
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  failedAt        DateTime?
  createdAt       DateTime  @default(now())

  notification    Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([recipientValue])
  @@index([status])
}

