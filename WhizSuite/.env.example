# =====================================
# Server Configuration
# =====================================
NODE_ENV=production
PORT=5000

# =====================================
# PostgreSQL
# For local Docker dev: postgresql://pranav:password@postgres:5432/postgres
# For AWS RDS: postgresql://user:password@your-rds-endpoint:5432/dbname
# =====================================
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=your_db_user
DB_PASSWORD=your_db_password

DATABASE_URL=postgresql://your_db_user:your_db_password@your-rds-endpoint.rds.amazonaws.com:5432/postgres?schema=public

# =====================================
# JWT Authentication
# =====================================
JWT_SECRET=change_me_to_a_strong_random_secret
JWT_EXPIRES_IN=7d

JWT_REFRESH_SECRET=change_me_to_a_strong_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# =====================================
# AWS S3
# =====================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your_s3_bucket_name

# =====================================
# Storage Mode
# =====================================
USE_LOCAL_STORAGE=false
LOCAL_STORAGE_PATH=./uploads

# =====================================
# Redis
# When running in Docker Compose use service name "redis"
# =====================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# =====================================
# CORS / Frontend
# =====================================
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# =====================================
# Next.js Client
# =====================================
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# =====================================
# OAuth – fill in only the platforms you use
# =====================================
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_API_VERSION=v18.0
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
