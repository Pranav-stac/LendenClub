pipeline {
    agent any

    environment {
        TRIVY_VERSION   = "0.50.1"
        TF_VERSION      = "1.7.0"
        TERRAFORM_DIR   = "WhizSuite/terraform"
        REPORT_FILE     = "trivy-report.txt"
        REPORT_HTML     = "trivy-report.html"
    }

    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {

        // ─────────────────────────────────────────────────────────
        // STAGE 1 – Checkout
        // ─────────────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                echo '========== STAGE 1: Checkout =========='
                checkout scm
                sh 'echo "Repository cloned successfully"'
                sh 'ls -la'
            }
        }

        // ─────────────────────────────────────────────────────────
        // STAGE 2 – Install Tooling (Trivy + Terraform)
        // ─────────────────────────────────────────────────────────
        stage('Install Tools') {
            steps {
                echo '========== STAGE 2: Installing Trivy & Terraform =========='

                // Install Trivy (IaC security scanner)
                sh '''
                    if ! command -v trivy &> /dev/null; then
                        echo "Installing Trivy ${TRIVY_VERSION}..."
                        curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh \
                            | sh -s -- -b /usr/local/bin v${TRIVY_VERSION}
                    else
                        echo "Trivy already installed: $(trivy --version)"
                    fi
                '''

                // Install Terraform
                sh '''
                    if ! command -v terraform &> /dev/null; then
                        echo "Installing Terraform ${TF_VERSION}..."
                        curl -fsSL https://releases.hashicorp.com/terraform/${TF_VERSION}/terraform_${TF_VERSION}_linux_amd64.zip \
                            -o /tmp/terraform.zip
                        unzip -o /tmp/terraform.zip -d /usr/local/bin
                        rm /tmp/terraform.zip
                    else
                        echo "Terraform already installed: $(terraform version)"
                    fi
                '''

                // Install Node.js (for Gemini AI remediation script)
                sh '''
                    if ! command -v node &> /dev/null; then
                        echo "Installing Node.js 20..."
                        curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
                        apt-get install -y nodejs 2>/dev/null || true
                        if command -v node &> /dev/null; then
                            echo "Node.js installed: $(node --version)"
                        else
                            echo "WARNING: Could not install Node.js. AI remediation may fail. Install manually if needed."
                        fi
                    else
                        echo "Node.js already installed: $(node --version)"
                    fi
                '''
            }
        }

        // ─────────────────────────────────────────────────────────
        // STAGE 3 – Infrastructure Security Scan (Trivy)
        //
        // This stage scans Terraform files for misconfigurations.
        //
        // FIRST RUN  → Will FAIL because security_groups.tf contains
        //              an intentional SSH 0.0.0.0/0 vulnerability.
        //
        // AFTER AI REMEDIATION → Re-run; scan should pass with 0
        //              CRITICAL/HIGH findings.
        // ─────────────────────────────────────────────────────────
        stage('Infrastructure Security Scan') {
            steps {
                echo '========== STAGE 3: Trivy IaC Security Scan =========='

                // Generate table report for console
                sh '''
                    echo "Running Trivy IaC scan on Terraform directory..."
                    trivy config \
                        --severity HIGH,CRITICAL \
                        --format table \
                        --output ${REPORT_FILE} \
                        ${TERRAFORM_DIR} || true

                    echo ""
                    echo "============================================================"
                    echo "              TRIVY SECURITY SCAN REPORT"
                    echo "============================================================"
                    cat ${REPORT_FILE}
                    echo "============================================================"
                '''

                // Generate HTML report for Jenkins archive
                sh '''
                    trivy config \
                        --severity HIGH,CRITICAL \
                        --format template \
                        --template "@contrib/html.tpl" \
                        --output ${REPORT_HTML} \
                        ${TERRAFORM_DIR} || true
                '''

                // Fail the stage if CRITICAL or HIGH findings exist
                // catchError allows pipeline to continue to AI Remediation stage
                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    sh '''
                        trivy config \
                            --severity HIGH,CRITICAL \
                            --exit-code 1 \
                            ${TERRAFORM_DIR}
                    '''
                }
            }

            post {
                always {
                    // Archive reports regardless of pass/fail
                    archiveArtifacts artifacts: "${REPORT_FILE}, ${REPORT_HTML}", allowEmptyArchive: true

                    // Publish HTML report to Jenkins UI
                    publishHTML(target: [
                        allowMissing         : true,
                        alwaysLinkToLastBuild: true,
                        keepAll              : true,
                        reportDir            : '.',
                        reportFiles          : "${REPORT_HTML}",
                        reportName           : 'Trivy Security Report'
                    ])
                }

                failure {
                    echo """
╔══════════════════════════════════════════════════════════════════╗
║  SECURITY SCAN FAILED – Vulnerabilities detected in Terraform   ║
║                                                                  ║
║  Steps to fix:                                                   ║
║  1. Review the Trivy report above (or in trivy-report.txt)       ║
║  2. Feed the report to AI for analysis and remediation advice    ║
║  3. Apply the AI-recommended changes to the Terraform files      ║
║  4. Re-run this pipeline                                         ║
╚══════════════════════════════════════════════════════════════════╝
                    """
                }

                success {
                    echo """
╔══════════════════════════════════════════════════════════════════╗
║  SECURITY SCAN PASSED – No CRITICAL/HIGH vulnerabilities found  ║
╚══════════════════════════════════════════════════════════════════╝
                    """
                }
            }
        }

        // ─────────────────────────────────────────────────────────
        // STAGE 4 – AI Remediation (Gemini 2.5 Flash + Tool Calling)
        //
        // Runs when GEMINI_API_KEY is set. Calls Gemini API to analyze
        // Trivy report and apply fixes to Terraform via tool calling.
        // Skips gracefully if GEMINI_API_KEY is not configured.
        // ─────────────────────────────────────────────────────────
        stage('AI Remediation') {
            steps {
                echo '========== STAGE 4: AI Remediation (Gemini 2.5 Flash) =========='

                dir('WhizSuite/scripts') {
                    sh '''
                        npm install
                        node ai-remediation.js
                    '''
                }
            }
            environment {
                WORKSPACE_ROOT = "${env.WORKSPACE}"
                REPORT_FILE    = "trivy-report.txt"
                TERRAFORM_DIR  = "WhizSuite/terraform"
            }
        }

        // ─────────────────────────────────────────────────────────
        // STAGE 5 – Security Re-scan (Verify Fixes)
        //
        // Re-runs Trivy after AI remediation. Must pass to continue.
        // ─────────────────────────────────────────────────────────
        stage('Security Re-scan') {
            steps {
                echo '========== STAGE 5: Trivy Re-scan (Verify Fixes) =========='

                sh '''
                    echo "Re-running Trivy to verify AI fixes..."
                    trivy config \
                        --severity HIGH,CRITICAL \
                        --format table \
                        ${TERRAFORM_DIR}

                    trivy config \
                        --severity HIGH,CRITICAL \
                        --exit-code 1 \
                        ${TERRAFORM_DIR}
                '''
            }
        }

        // ─────────────────────────────────────────────────────────
        // STAGE 6 – Terraform Plan
        // Only runs after security re-scan passes
        // ─────────────────────────────────────────────────────────
        stage('Terraform Plan') {
            steps {
                echo '========== STAGE 6: Terraform Plan =========='

                dir("${TERRAFORM_DIR}") {
                    sh '''
                        echo "Initialising Terraform..."
                        terraform init -input=false

                        echo ""
                        echo "Running Terraform plan..."
                        terraform plan \
                            -input=false \
                            -out=tfplan \
                            -var="aws_region=ap-south-1"

                        echo ""
                        echo "Terraform plan complete. Review output above before applying."
                    '''
                }
            }

            post {
                always {
                    archiveArtifacts artifacts: "${TERRAFORM_DIR}/tfplan", allowEmptyArchive: true
                }
            }
        }
    }

    post {
        success {
            echo """
╔══════════════════════════════════════════════════════════════════╗
║  PIPELINE SUCCEEDED                                              ║
║  All stages passed. Infrastructure is ready to deploy.           ║
╚══════════════════════════════════════════════════════════════════╝
            """
        }

        failure {
            echo """
╔══════════════════════════════════════════════════════════════════╗
║  PIPELINE FAILED                                                 ║
║  Review the stage logs above for details.                        ║
╚══════════════════════════════════════════════════════════════════╝
            """
        }

        always {
            cleanWs(cleanWhenNotBuilt: false,
                    deleteDirs: true,
                    disableDeferredWipeout: true,
                    notFailBuild: true,
                    patterns: [[pattern: '.gitignore', type: 'INCLUDE'],
                               [pattern: '.propsfile', type: 'EXCLUDE']])
        }
    }
}
