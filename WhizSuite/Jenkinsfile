pipeline {
    agent any

    parameters {
        string(name: 'GITHUB_REPO_URL', defaultValue: 'https://github.com/Pranav-stac/LendenClub', description: 'Git repo URL for EC2 to clone (must contain WhizSuite/)')
    }

    environment {
        TRIVY_VERSION   = "0.69.3"
        TF_VERSION      = "1.7.0"
        TERRAFORM_DIR   = "WhizSuite/terraform"
        REPORT_FILE     = "trivy-report.txt"
        REPORT_HTML     = "trivy-report.html"
        TOOLS_DIR       = "${env.WORKSPACE}/.tools"
        PATH            = "${env.WORKSPACE}/.tools/node-v20.18.0-linux-x64/bin:${env.WORKSPACE}/.tools:${env.PATH}"
    }

    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {

        // ─────────────────────────────────────────────────────────
        // STAGE 1 – Checkout
        // ─────────────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                echo '========== STAGE 1: Checkout =========='
                checkout scm
                script {
                    if (isUnix()) {
                        sh 'echo "Repository cloned successfully"'
                        sh 'ls -la'
                    } else {
                        bat 'echo Repository cloned successfully'
                        bat 'dir /b'
                    }
                }
            }
        }

        // ─────────────────────────────────────────────────────────
        // STAGE 2 – Install Tooling (Trivy + Terraform + Node)
        // Uses $WORKSPACE/.tools (user-writable) – Jenkins runs non-root
        // ─────────────────────────────────────────────────────────
        stage('Install Tools') {
            steps {
                echo '========== STAGE 2: Installing Trivy & Terraform =========='
                script {
                    if (isUnix()) {
                        sh '''
                            set -e
                            TOOLS_DIR="${WORKSPACE}/.tools"
                            mkdir -p "$TOOLS_DIR"
                            export PATH="$TOOLS_DIR:$PATH"

                            if ! command -v trivy &> /dev/null; then
                                echo "Installing Trivy ${TRIVY_VERSION} to $TOOLS_DIR (direct download)..."
                                curl -sfSL "https://github.com/aquasecurity/trivy/releases/download/v${TRIVY_VERSION}/trivy_${TRIVY_VERSION}_Linux-64bit.tar.gz" -o /tmp/trivy.tar.gz
                                (cd /tmp && tar -xzf trivy.tar.gz)
                                TRIVY_BIN=$(find /tmp -maxdepth 2 -name trivy -type f 2>/dev/null | head -1)
                                [ -n "$TRIVY_BIN" ] && mv "$TRIVY_BIN" "$TOOLS_DIR/trivy" && chmod +x "$TOOLS_DIR/trivy"
                                rm -rf /tmp/trivy.tar.gz /tmp/trivy /tmp/trivy_*
                                echo "Trivy installed: $(trivy --version)"
                            else
                                echo "Trivy already installed: $(trivy --version)"
                            fi

                            if ! command -v terraform &> /dev/null; then
                                echo "Installing Terraform ${TF_VERSION} to $TOOLS_DIR..."
                                cd "$TOOLS_DIR"
                                curl -fsSL "https://releases.hashicorp.com/terraform/${TF_VERSION}/terraform_${TF_VERSION}_linux_amd64.zip" -o tf.zip
                                (unzip -o tf.zip 2>/dev/null) || (jar xf tf.zip)
                                rm -f tf.zip
                                cd -
                                echo "Terraform installed: $(terraform version)"
                            else
                                echo "Terraform already installed: $(terraform version)"
                            fi

                            if ! command -v node &> /dev/null; then
                                echo "Installing Node.js 20 to $TOOLS_DIR..."
                                curl -fsSL "https://nodejs.org/dist/v20.18.0/node-v20.18.0-linux-x64.tar.gz" -o /tmp/node.tar.gz
                                tar -xzf /tmp/node.tar.gz -C "$TOOLS_DIR"
                                rm -f /tmp/node.tar.gz
                                export PATH="$TOOLS_DIR/node-v20.18.0-linux-x64/bin:$PATH"
                                echo "Node.js installed: $(node --version)"
                            else
                                echo "Node.js already installed: $(node --version)"
                            fi

                            echo "Tools in $TOOLS_DIR:" && ls -la "$TOOLS_DIR"
                        '''
                    } else {
                        // Windows: download Trivy, Terraform, Node to workspace .tools dir
                        powershell '''
                            $toolsDir = "$env:WORKSPACE\\.tools"
                            New-Item -ItemType Directory -Force -Path $toolsDir | Out-Null
                            $env:PATH = "$toolsDir;$env:PATH"

                            # Trivy
                            if (-not (Get-Command trivy -ErrorAction SilentlyContinue)) {
                                Write-Host "Installing Trivy $env:TRIVY_VERSION..."
                                $url = "https://github.com/aquasecurity/trivy/releases/download/v$env:TRIVY_VERSION/trivy_$env:TRIVY_VERSION`_Windows-64bit.zip"
                                Invoke-WebRequest -Uri $url -OutFile "$toolsDir\\trivy.zip" -UseBasicParsing
                                Expand-Archive -Path "$toolsDir\\trivy.zip" -DestinationPath $toolsDir -Force
                                Remove-Item "$toolsDir\\trivy.zip" -Force
                            }
                            Write-Host "Trivy: $(trivy --version 2>$null)"

                            # Terraform
                            if (-not (Get-Command terraform -ErrorAction SilentlyContinue)) {
                                Write-Host "Installing Terraform $env:TF_VERSION..."
                                $url = "https://releases.hashicorp.com/terraform/$env:TF_VERSION/terraform_$env:TF_VERSION`_windows_amd64.zip"
                                Invoke-WebRequest -Uri $url -OutFile "$toolsDir\\tf.zip" -UseBasicParsing
                                Expand-Archive -Path "$toolsDir\\tf.zip" -DestinationPath $toolsDir -Force
                                Remove-Item "$toolsDir\\tf.zip" -Force
                            }
                            Write-Host "Terraform: $(terraform version 2>$null)"

                            # Node.js
                            if (-not (Get-Command node -ErrorAction SilentlyContinue)) {
                                Write-Host "Installing Node.js 20..."
                                $nodeZip = "$toolsDir\\node.zip"
                                Invoke-WebRequest -Uri "https://nodejs.org/dist/v20.18.0/node-v20.18.0-win-x64.zip" -OutFile $nodeZip -UseBasicParsing
                                Expand-Archive -Path $nodeZip -DestinationPath $toolsDir -Force
                                Remove-Item $nodeZip -Force
                                $env:PATH = "$toolsDir\\node-v20.18.0-win-x64;$env:PATH"
                            }
                            Write-Host "Node: $(node --version)"
                        '''
                    }
                }
            }
        }

        // ─────────────────────────────────────────────────────────
        // STAGE 3 – Infrastructure Security Scan (Trivy)
        //
        // This stage scans Terraform files for misconfigurations.
        //
        // FIRST RUN  → Will FAIL because security_groups.tf contains
        //              an intentional SSH 0.0.0.0/0 vulnerability.
        //
        // AFTER AI REMEDIATION → Re-run; scan should pass with 0
        //              CRITICAL/HIGH findings.
        // ─────────────────────────────────────────────────────────
        stage('Infrastructure Security Scan') {
            steps {
                echo '========== STAGE 3: Trivy IaC Security Scan =========='
                script {
                    if (isUnix()) {
                        // Generate table report for console
                        sh '''
                            echo "Running Trivy IaC scan on Terraform directory..."
                            trivy config \
                                --severity HIGH,CRITICAL \
                                --format table \
                                --output ${REPORT_FILE} \
                                ${TERRAFORM_DIR} || true

                            echo ""
                            echo "============================================================"
                            echo "              TRIVY SECURITY SCAN REPORT"
                            echo "============================================================"
                            cat ${REPORT_FILE}
                            echo "============================================================"
                        '''

                        // HTML report skipped – @contrib/html.tpl not bundled in Trivy 0.69
                        // Table report (trivy-report.txt) is archived and used by AI remediation

                        // Fail the stage if CRITICAL or HIGH findings exist
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh '''
                                trivy config \
                                    --severity HIGH,CRITICAL \
                                    --exit-code 1 \
                                    ${TERRAFORM_DIR}
                            '''
                        }
                    } else {
                        powershell '''
                            $env:PATH = "$env:WORKSPACE\\.tools;$env:PATH"
                            Write-Host "Running Trivy IaC scan on Terraform directory..."
                            trivy config --severity HIGH,CRITICAL --format table --output $env:REPORT_FILE $env:TERRAFORM_DIR; if ($LASTEXITCODE -ne 0) { $true }
                            Write-Host ""
                            Write-Host "============================================================"
                            Write-Host "              TRIVY SECURITY SCAN REPORT"
                            Write-Host "============================================================"
                            Get-Content $env:REPORT_FILE -ErrorAction SilentlyContinue
                            Write-Host "============================================================"
                        '''
                        // HTML report skipped – table report used for AI remediation
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            powershell '''
                                $env:PATH = "$env:WORKSPACE\\.tools;$env:PATH"
                                trivy config --severity HIGH,CRITICAL --exit-code 1 $env:TERRAFORM_DIR
                            '''
                        }
                    }
                }
            }

            post {
                always {
                    // Archive table report (publishHTML plugin not installed, skip HTML)
                    archiveArtifacts artifacts: "${REPORT_FILE}", allowEmptyArchive: true
                }

                failure {
                    echo """
╔══════════════════════════════════════════════════════════════════╗
║  SECURITY SCAN FAILED – Vulnerabilities detected in Terraform   ║
║                                                                  ║
║  Steps to fix:                                                   ║
║  1. Review the Trivy report above (or in trivy-report.txt)       ║
║  2. Feed the report to AI for analysis and remediation advice    ║
║  3. Apply the AI-recommended changes to the Terraform files      ║
║  4. Re-run this pipeline                                         ║
╚══════════════════════════════════════════════════════════════════╝
                    """
                }

                success {
                    echo """
╔══════════════════════════════════════════════════════════════════╗
║  SECURITY SCAN PASSED – No CRITICAL/HIGH vulnerabilities found  ║
╚══════════════════════════════════════════════════════════════════╝
                    """
                }
            }
        }

        // ─────────────────────────────────────────────────────────
        // STAGE 4 – AI Remediation (Gemini 2.5 Flash + Tool Calling)
        //
        // Runs when GEMINI_API_KEY is set. Calls Gemini API to analyze
        // Trivy report and apply fixes to Terraform via tool calling.
        // Skips gracefully if GEMINI_API_KEY is not configured.
        // ─────────────────────────────────────────────────────────
        stage('AI Remediation') {
            environment {
                WORKSPACE_ROOT = "${env.WORKSPACE}"
                REPORT_FILE    = "trivy-report.txt"
                TERRAFORM_DIR  = "WhizSuite/terraform"
            }
            steps {
                echo '========== STAGE 4: AI Remediation (Gemini 2.5 Flash) =========='
                withCredentials([string(credentialsId: 'gemini-api-key', variable: 'GEMINI_API_KEY')]) {
                    dir('WhizSuite/scripts') {
                        script {
                            if (isUnix()) {
                                sh 'npm install && node ai-remediation.js'
                            } else {
                                powershell '''
                                    $toolsDir = "$env:WORKSPACE\\.tools"
                                    if (Test-Path "$toolsDir\node-v20*") {
                                        $nodeDir = Get-ChildItem "$toolsDir\node-v20*" -Directory | Select-Object -First 1
                                        $env:PATH = "$($nodeDir.FullName);$env:PATH"
                                    }
                                    npm install; node ai-remediation.js
                                '''
                            }
                        }
                    }
                }
            }
        }

        // ─────────────────────────────────────────────────────────
        // STAGE 5 – Security Re-scan (Verify Fixes)
        //
        // Re-runs Trivy after AI remediation. Must pass to continue.
        // ─────────────────────────────────────────────────────────
        stage('Security Re-scan') {
            steps {
                echo '========== STAGE 5: Trivy Re-scan (Verify Fixes) =========='
                script {
                    if (isUnix()) {
                        sh '''
                            echo "Re-running Trivy to verify AI fixes..."
                            trivy config \
                                --severity HIGH,CRITICAL \
                                --format table \
                                ${TERRAFORM_DIR}

                            trivy config \
                                --severity HIGH,CRITICAL \
                                --exit-code 1 \
                                ${TERRAFORM_DIR}
                        '''
                    } else {
                        powershell '''
                            $env:PATH = "$env:WORKSPACE\\.tools;$env:PATH"
                            Write-Host "Re-running Trivy to verify AI fixes..."
                            trivy config --severity HIGH,CRITICAL --format table $env:TERRAFORM_DIR
                            trivy config --severity HIGH,CRITICAL --exit-code 1 $env:TERRAFORM_DIR
                        '''
                    }
                }
            }
        }

        // ─────────────────────────────────────────────────────────
        // STAGE 6 – Terraform Plan (or Validate)
        // With aws-terraform-credentials: runs terraform plan
        // Without credentials: runs terraform validate (no AWS, pipeline still passes)
        // ─────────────────────────────────────────────────────────
        stage('Terraform Plan') {
            steps {
                echo '========== STAGE 6: Terraform Plan =========='
                script {
                    def credError = null
                    try {
                        withCredentials([
                            usernamePassword(
                                credentialsId: 'aws-terraform-credentials',
                                usernameVariable: 'AWS_ACCESS_KEY_ID',
                                passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                            )
                        ]) {
                            dir("${TERRAFORM_DIR}") {
                                if (isUnix()) {
                                    sh """
                                        echo "Initialising Terraform..."
                                        terraform init -input=false
                                        echo ""
                                        echo "Running Terraform plan..."
                                        terraform plan -input=false -out=tfplan \
                                            -var="aws_region=ap-south-1" \
                                            -var="github_repo_url=${params.GITHUB_REPO_URL}"
                                        echo ""
                                        echo "Terraform plan complete. Review output above before applying."
                                    """
                                } else {
                                    powershell """
                                        \$env:PATH = \"\$env:WORKSPACE\\.tools;\$env:PATH\"
                                        Write-Host "Initialising Terraform..."
                                        terraform init -input=false
                                        Write-Host ""
                                        Write-Host "Running Terraform plan..."
                                        terraform plan -input=false -out=tfplan -var=\"aws_region=ap-south-1\" -var=\"github_repo_url=${params.GITHUB_REPO_URL}\"
                                        Write-Host ""
                                        Write-Host "Terraform plan complete. Review output above before applying."
                                    """
                                }
                            }
                        }
                    } catch (e) {
                        if (e.message?.contains('Could not find credentials') || e.message?.contains('credentials entry')) {
                            credError = e
                        } else {
                            throw e
                        }
                    }
                    if (credError) {
                        echo ''
                        echo 'AWS credentials (aws-terraform-credentials) not configured.'
                        echo 'Running terraform validate instead of plan (no AWS needed).'
                        echo 'To run full plan: add credential in Jenkins (Step 5 of JENKINS_SETUP.md).'
                        echo ''
                        dir("${TERRAFORM_DIR}") {
                            if (isUnix()) {
                                sh '''
                                    terraform init -input=false
                                    terraform validate
                                    echo ""
                                    echo "Terraform config is valid. Add aws-terraform-credentials for full plan."
                                '''
                            } else {
                                powershell '''
                                    $env:PATH = "$env:WORKSPACE\\.tools;$env:PATH"
                                    terraform init -input=false
                                    terraform validate
                                    Write-Host ""
                                    Write-Host "Terraform config is valid. Add aws-terraform-credentials for full plan."
                                '''
                            }
                        }
                    }
                }
            }

            post {
                always {
                    archiveArtifacts artifacts: "${TERRAFORM_DIR}/tfplan", allowEmptyArchive: true
                }
            }
        }

        // ─────────────────────────────────────────────────────────
        // STAGE 7 – Terraform Apply (Automatic AWS Deployment)
        // Deploys EC2 + security group to AWS when plan succeeded with credentials.
        // EC2 user-data clones repo and runs docker-compose – app goes live.
        // ─────────────────────────────────────────────────────────
        stage('Terraform Apply') {
            steps {
                echo '========== STAGE 7: Terraform Apply (Automatic Deployment) =========='
                script {
                    def applyCredError = null
                    try {
                        withCredentials([
                            usernamePassword(
                                credentialsId: 'aws-terraform-credentials',
                                usernameVariable: 'AWS_ACCESS_KEY_ID',
                                passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                            )
                        ]) {
                            dir("${TERRAFORM_DIR}") {
                                if (fileExists('tfplan')) {
                                    if (isUnix()) {
                                        sh '''
                                            echo "Applying Terraform plan – deploying to AWS..."
                                            terraform apply -input=false -auto-approve tfplan
                                            echo ""
                                            echo "========== DEPLOYMENT COMPLETE =========="
                                            terraform output -json 2>/dev/null || true
                                            echo ""
                                            echo "App URL:  $(terraform output -raw app_url 2>/dev/null || echo 'Check terraform output')"
                                            echo "API URL:  $(terraform output -raw api_url 2>/dev/null || echo 'Check terraform output')"
                                            echo "Public IP: $(terraform output -raw public_ip 2>/dev/null || echo 'Check terraform output')"
                                        '''
                                    } else {
                                        powershell '''
                                            $env:PATH = "$env:WORKSPACE\\.tools;$env:PATH"
                                            Write-Host "Applying Terraform plan – deploying to AWS..."
                                            terraform apply -input=false -auto-approve tfplan
                                            Write-Host ""
                                            Write-Host "========== DEPLOYMENT COMPLETE =========="
                                            terraform output
                                        '''
                                    }
                                } else {
                                    echo 'No tfplan found – skipping apply. (Run with AWS credentials for full plan + deploy.)'
                                }
                            }
                        }
                    } catch (e) {
                        if (e.message?.contains('Could not find credentials') || e.message?.contains('credentials entry')) {
                            applyCredError = e
                            echo ''
                            echo 'AWS credentials not configured – skipping automatic deployment.'
                            echo 'Add aws-terraform-credentials for full pipeline (plan + apply).'
                        } else {
                            throw e
                        }
                    }
                }
            }
            post {
                success {
                    dir("${TERRAFORM_DIR}") {
                        script {
                            if (fileExists('tfplan') && isUnix()) {
                                sh 'terraform output -json 2>/dev/null | head -50 || true'
                            }
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            echo """
╔══════════════════════════════════════════════════════════════════╗
║  PIPELINE SUCCEEDED                                              ║
║  All stages passed. Infrastructure is ready to deploy.           ║
╚══════════════════════════════════════════════════════════════════╝
            """
        }

        failure {
            echo """
╔══════════════════════════════════════════════════════════════════╗
║  PIPELINE FAILED                                                 ║
║  Review the stage logs above for details.                        ║
╚══════════════════════════════════════════════════════════════════╝
            """
        }

        always {
            cleanWs(cleanWhenNotBuilt: false,
                    deleteDirs: true,
                    disableDeferredWipeout: true,
                    notFailBuild: true,
                    patterns: [[pattern: '.gitignore', type: 'INCLUDE'],
                               [pattern: '.propsfile', type: 'EXCLUDE']])
        }
    }
}
